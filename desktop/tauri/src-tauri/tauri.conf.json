{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../app",
    "distDir": "../app"
  },
  "package": {
    "productName": "chasingclaw",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "all": false,
        "execute": true,
        "sidecar": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.chasingclaw.desktop",
      "icon": [
        "icons/icon.png",
        "icons/icon.ico"
      ],
      "externalBin": [
        "bin/chasingclaw-ui"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "offlineInstaller"
        }
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "chasingclaw",
        "url": "index.html",
        "width": 1320,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    }
  }
}
